# Application
APP_NAME=go-template
APP_ENV=development
APP_DEBUG=true

# Server
SERVER_HOST=0.0.0.0
SERVER_PORT=3000
SERVER_READ_TIMEOUT=10s
SERVER_WRITE_TIMEOUT=10s
SERVER_IDLE_TIMEOUT=120s
SERVER_SHUTDOWN_TIMEOUT=30s

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=go-template
DB_SSL_MODE=disable
DB_MAX_IDLE_CONNS=10
DB_MAX_OPEN_CONNS=100
DB_MAX_LIFETIME=1h
DB_SLOW_QUERY_THRESHOLD=200ms
DB_RETRY_ATTEMPTS=5
DB_RETRY_DELAY=5s

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_RETRY_ATTEMPTS=5
REDIS_RETRY_DELAY=5s

# JWT
JWT_SECRET=your-super-secret-key-change-in-production-min-32-chars
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=168h
JWT_ISSUER=go-template

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Self-Registration
SELF_REGISTRATION_ENABLED=false
SELF_REGISTRATION_REQUIRE_EMAIL_VERIFICATION=true
SELF_REGISTRATION_VERIFICATION_TOKEN_EXPIRY=24h
SELF_REGISTRATION_PASSWORD_RESET_TOKEN_EXPIRY=1h
SELF_REGISTRATION_DEFAULT_ROLE=self_registered
SELF_REGISTRATION_BASE_URL=http://localhost:5173

# SMTP (for email verification and password reset)
SMTP_HOST=localhost
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=noreply@example.com
SMTP_FROM_NAME=Go Template
SMTP_USE_TLS=true

# OAuth - Google
OAUTH_GOOGLE_ENABLED=false
OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_SECRET=
OAUTH_GOOGLE_REDIRECT_URL=http://localhost:3000/api/auth/oauth/google/callback

# OAuth - Facebook
OAUTH_FACEBOOK_ENABLED=false
OAUTH_FACEBOOK_CLIENT_ID=
OAUTH_FACEBOOK_CLIENT_SECRET=
OAUTH_FACEBOOK_REDIRECT_URL=http://localhost:3000/api/auth/oauth/facebook/callback

# OAuth - Apple
OAUTH_APPLE_ENABLED=false
OAUTH_APPLE_CLIENT_ID=
OAUTH_APPLE_CLIENT_SECRET=
OAUTH_APPLE_REDIRECT_URL=http://localhost:3000/api/auth/oauth/apple/callback
